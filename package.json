{
	"name": "pi-action",
	"version": "1.4.4",
	"description": "GitHub Action to invoke the pi coding agent on issues and PRs",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"keywords": ["github-action", "pi", "ai", "coding-agent", "automation"],
	"author": "Carlos Villela",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cv/pi-action.git"
	},
	"bugs": {
		"url": "https://github.com/cv/pi-action/issues"
	},
	"homepage": "https://github.com/cv/pi-action#readme",
	"dependencies": {
		"@actions/core": "^1.10.1",
		"@actions/github": "^6.0.0",
		"@mariozechner/pi-coding-agent": "^0.33.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@commitlint/cli": "^20.3.0",
		"@commitlint/config-conventional": "^20.3.0",
		"@types/node": "^20.17.12",
		"@vitest/coverage-v8": "^2.1.9",
		"husky": "^9.1.7",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
