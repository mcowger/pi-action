{
  "branches": ["v2"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "releaseRules": [
          { "type": "chore", "scope": "deps", "release": "patch" },
          { "type": "fix", "scope": "deps", "release": "patch" },
          { "type": "fix", "scope": "deps-dev", "release": "patch" }
        ]
      }
    ],
    "@alexanderfortin/semantic-release-keep-a-changelog",
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bun run scripts/bump-readme-version.ts ${nextRelease.version} && bun run package"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md", "README.md", "dist/index.js"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": ["dist/*"],
        "successComment": false
      }
    ]
  ],
  "tagFormat": "v${version}",
  "npmPublish": false
}
