#!/bin/sh

# Auto-append issue number from branch name to commit message
# Example: branch "fix/123-bug-description" will append "Refs #123" to commit

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only modify if this is a regular commit (not merge, squash, etc.)
if [ -z "$COMMIT_SOURCE" ]; then
    BRANCH_NAME=$(git symbolic-ref --short HEAD 2>/dev/null)
    
    # Extract issue number from branch name (e.g., "feat/123-description" or "fix-456-thing")
    ISSUE_NUMBER=$(echo "$BRANCH_NAME" | grep -oE '[0-9]+' | head -1)
    
    if [ -n "$ISSUE_NUMBER" ]; then
        # Check if the commit message already references this issue
        if ! grep -qE "#$ISSUE_NUMBER" "$COMMIT_MSG_FILE"; then
            # Append issue reference to commit message
            echo "" >> "$COMMIT_MSG_FILE"
            echo "Refs #$ISSUE_NUMBER" >> "$COMMIT_MSG_FILE"
        fi
    fi
fi
