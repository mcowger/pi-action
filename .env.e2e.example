# Copy this file to .env.e2e and fill in values to run end-to-end tests.
# .env.e2e is gitignored and will never be committed.

# Contents of ~/.pi/agent/auth.json (required unless PI_MODELS_JSON has inline apiKey)
PI_AUTH_JSON=

# Contents of ~/.pi/agent/models.json (optional - for custom providers with inline apiKey)
PI_MODELS_JSON=

# Provider to test with (default: anthropic)
E2E_PROVIDER=anthropic

# Model to test with (default: claude-sonnet-4-20250514)
E2E_MODEL=claude-sonnet-4-20250514
