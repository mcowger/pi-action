{
	"compilerOptions": {
		"target": "ES2025",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true
	},
	"include": ["src/**/*"],
	"exclude": ["src/**/*.test.ts"]
}
